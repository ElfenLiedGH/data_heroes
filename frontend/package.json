{
  "name": "notification-preferences-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "prebuild": "npm run api:generate",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "npm run typecheck && npm run lint && vitest run",
    "test:watch": "vitest",
    "api:generate": "node --input-type=module -e \"import { mkdirSync } from 'node:fs'; mkdirSync('src/shared/api/generated', { recursive: true });\" && rtk-query-codegen-openapi openapi.config.mjs"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.5.0",
    "@smwb/summer-ui": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.76.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@rtk-query/codegen-openapi": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "less": "^4.6.4",
    "tsx": "^4.22.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
